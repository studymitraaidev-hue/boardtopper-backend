# ─── BoardTopper AI — Frontend Environment Variables ───────────────────────────
# Copy this file to .env.local for local development.
# On Vercel: add these under Project → Settings → Environment Variables.
# NEVER commit .env.local to git.

# ── Backend API URL (REQUIRED in production) ──────────────────────────────────
# Set to your Railway backend URL after deploying the backend.
VITE_API_URL=https://your-backend.railway.app

# ── Supabase (REQUIRED for Google OAuth) ──────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
# Use the PUBLIC anon key here (safe to expose in browser).
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sentry (optional — error tracking) ───────────────────────────────────────
# Get from: https://sentry.io → Projects → your project → Settings → SDK Setup
VITE_SENTRY_DSN_FRONTEND=https://xxx@xxx.ingest.sentry.io/xxx
