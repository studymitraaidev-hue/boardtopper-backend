# ─── BoardTopper AI — Backend Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# On Railway: set these in the project's Variables tab (not this file).
# NEVER commit the actual .env file to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string_minimum_32_chars
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=12

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# anon/public key
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# service_role key (keep secret — server-side only)
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# service_role key for OAuth verification (same as SUPABASE_SECRET_KEY usually)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AI (REQUIRED) ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...
# Optional fallback AI (Groq) — get from: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── CORS (REQUIRED in production) ────────────────────────────────────────────
# Set to your Vercel frontend URL. Comma-separated for multiple origins.
CORS_ORIGIN=https://your-app.vercel.app

# ── Frontend URL (REQUIRED for email links) ───────────────────────────────────
APP_URL=https://your-app.vercel.app

# ── Email — Resend (optional but recommended) ─────────────────────────────────
# Without this, no emails are sent (registration still works, just no welcome email).
# Get from: https://resend.com
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Without Redis, JWT revocation uses in-memory store (lost on restart).
# Add a Railway Redis plugin and paste the URL here for persistent revocation.
REDIS_URL=redis://default:password@host:6379

# ── Razorpay (optional — payments disabled until set) ─────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for testing, rzp_live_... for production.
# Payments return 503 until both keys are configured.
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Admin cron secret ─────────────────────────────────────────────────────────
# Secures /api/admin/expire-subscriptions endpoint.
# Generate: openssl rand -hex 16
ADMIN_SECRET=replace_with_32_char_random_hex
